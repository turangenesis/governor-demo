# Copy to .env and fill in. .env is gitignored — never commit real values.
# The whole demo runs with NONE of these set (cached data, no LLM, stub sends).
# Fill these in only to turn on live features.

# --- Real LLM drafting (optional) --------------------------------------------
# The agents draft real Claude emails only when "Live LLM drafting" is toggled ON
# in the UI AND one of these providers is configured. Pick ONE:
#
# (A) Anthropic API — simplest. A PAID api key from console.anthropic.com.
#     NOTE: this is NOT your claude.ai subscription — a subscription can't power an app.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8
#
# (B) AWS Bedrock — the hackathon sponsor path. Scoped IAM user, Bedrock invoke only.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1
BEDROCK_MODEL_ID=us.anthropic.claude-sonnet-4-5-20250929-v1:0
#
# Force a provider (optional): anthropic | bedrock. Default: anthropic if a key is set.
# LLM_PROVIDER=anthropic

# --- GitHub discovery (optional) ---------------------------------------------
# Unauthenticated search is 60 req/hr. Set a token to lift it; not needed if the
# per-query cache is warm (the default demo replays it offline).
# GITHUB_TOKEN=

# --- Zero.xyz (Step 3) ---
# Uses only the $5 starting credit. Do NOT fund the wallet further.
ZERO_API_KEY=
# Flip to "stub" for the safe demo fallback; "real" to actually send via Zero.
ZERO_MODE=stub

# --- Demo recipient (where gated outreach actually goes during a live demo) ---
# Point this at YOUR inbox so no real candidate is ever emailed.
DEMO_RECIPIENT_EMAIL=
